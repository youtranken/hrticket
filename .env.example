# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgres://hris:hris@localhost:5432/hris

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000
# Comma-separated origins allowed by CORS (web dev server)
WEB_ORIGIN=http://localhost:5173

# ─── Session & crypto secrets (generate strong random in prod) ─
SESSION_SECRET=change-me-32-bytes-min-session-secret
HMAC_SIGNING_KEY=change-me-32-bytes-min-hmac-key
ATTACHMENT_ENCRYPTION_KEY=change-me-32-bytes-aes-key

# ─── Attachment storage (filesystem) ──────────────────────
ATTACHMENT_STORAGE_ROOT=./attachments

# ─── IMAP (per project — bootstrap; UI-managed from Story 11.1) ─
# DEV/TEST mailbox only. NEVER point at production.
IMAP_HRIS_HOST=localhost
IMAP_HRIS_PORT=143
IMAP_HRIS_USER=leminh@pmh.com.vn
IMAP_HRIS_PASSWORD=app-password-here
IMAP_CNB_HOST=localhost
IMAP_CNB_PORT=143
IMAP_CNB_USER=leminh+cnb@pmh.com.vn
IMAP_CNB_PASSWORD=app-password-here

# ─── SMTP (per project) ───────────────────────────────────
SMTP_HRIS_HOST=localhost
SMTP_HRIS_PORT=1025
SMTP_HRIS_USER=leminh@pmh.com.vn
SMTP_HRIS_PASSWORD=app-password-here
SMTP_CNB_HOST=localhost
SMTP_CNB_PORT=1025
SMTP_CNB_USER=leminh+cnb@pmh.com.vn
SMTP_CNB_PASSWORD=app-password-here

# ─── Seed (first SSA account) ─────────────────────────────
SEED_SSA_EMAIL=ssa@pmh.com.vn
SEED_SSA_PASSWORD=change-me-on-first-login
