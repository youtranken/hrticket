# ============================================================================
# PRODUCTION .env  — copy to `.env`, fill in REAL values, chmod 600, DO NOT commit.
# Used by docker-compose.prod.yml (${VAR} interpolation) + passed into containers.
# Generate each secret with:  openssl rand -base64 32
# ============================================================================

# ─── Database ───────────────────────────────────────────────
# Strong password; DATABASE_URL in compose is built from this.
POSTGRES_PASSWORD=__CHANGE_ME_strong_db_password__

# ─── App secrets (≥16 chars; app fails to boot if missing/short) ─
SESSION_SECRET=__CHANGE_ME_rand_32__
HMAC_SIGNING_KEY=__CHANGE_ME_rand_32__
ATTACHMENT_ENCRYPTION_KEY=__CHANGE_ME_rand_32__
EMAIL_SECRET_KEY=__CHANGE_ME_rand_32__

# ─── Public URLs (HTTPS domain users actually reach) ─────────
# Must include the public port if it is not 443 — the session cookie is secure=true
# and WEB_ORIGIN gates CORS, so a mismatch here means nobody can log in.
APP_BASE_URL=https://hrticket.pmh.com.vn:8443
WEB_ORIGIN=https://hrticket.pmh.com.vn:8443

# ─── Host ports for the web container ───────────────────────
# WEB_PUBLIC_PORT is BOTH the host port mapped to nginx:443 AND the port nginx puts
# in its HTTP→HTTPS redirect. Keep it equal to the port in APP_BASE_URL/WEB_ORIGIN.
WEB_PUBLIC_PORT=8443
WEB_HTTP_PORT=8080

# ─── Attachment storage (host folder bind-mounted into api+worker) ─
# Path on the HOST, relative to docker-compose.prod.yml (default ../attachments).
ATTACHMENT_HOST_DIR=../attachments

# ─── Real mailbox per project ───────────────────────────────
# You can leave these blank and configure everything in /admin/email-connection
# (DB wins over env, hot-swappable). If set here, they are the bootstrap fallback.
# Ports: 993/465 ⇒ TLS; 587 ⇒ STARTTLS. CẤM trỏ mailbox production trong test.
IMAP_HRIS_HOST=
IMAP_HRIS_PORT=993
IMAP_HRIS_USER=
IMAP_HRIS_PASSWORD=
IMAP_HRIS_SECURE=true
SMTP_HRIS_HOST=
SMTP_HRIS_PORT=465
SMTP_HRIS_USER=
SMTP_HRIS_PASSWORD=
SMTP_HRIS_SECURE=true
SMTP_HRIS_FROM=

IMAP_CNB_HOST=
IMAP_CNB_PORT=993
IMAP_CNB_USER=
IMAP_CNB_PASSWORD=
IMAP_CNB_SECURE=true
SMTP_CNB_HOST=
SMTP_CNB_PORT=465
SMTP_CNB_USER=
SMTP_CNB_PASSWORD=
SMTP_CNB_SECURE=true
SMTP_CNB_FROM=

# ─── Seed (first SSA account; used once by `db:seed`) ───────
SEED_SSA_EMAIL=ssa@pmh.com.vn
SEED_SSA_PASSWORD=__CHANGE_ME_then_change_on_first_login__

# NEVER true in production.
SEED_DEV_USERS=false
