{
  "name": "@hris/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint src",
    "test": "jest",
    "test:it": "jest --config test/jest-it.config.cjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node -r ts-node/register/transpile-only src/infra/db/migrate.ts",
    "db:seed": "node -r ts-node/register/transpile-only src/infra/db/seed.ts"
  },
  "dependencies": {
    "@hris/shared": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.38.3",
    "drizzle-zod": "^0.6.1",
    "nestjs-pino": "^4.3.0",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "drizzle-kit": "^0.30.1",
    "testcontainers": "^10.16.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
