{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "infra/db/migrations/**/*.sql",
      "infra/db/migrations/meta/**/*.json",
      "infra/db/sql/**/*.sql"
    ],
    "watchAssets": true
  }
}
