{
  "name": "hris-ticket",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm -r test",
    "test:it": "pnpm --filter @hris/api test:it",
    "db:generate": "pnpm --filter @hris/api db:generate",
    "db:migrate": "pnpm --filter @hris/api db:migrate",
    "db:seed": "pnpm --filter @hris/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-plugin-i18next": "^6.1.4",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
