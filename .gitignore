# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Env & secrets
.env
.env.*
!.env.example
!.env.prod.example
*.local

# Attachments storage (filesystem — never commit user files)
attachments/
storage/
# ...but the broad `storage/` rule above also matched a SOURCE directory of the same
# name. Re-include it — this is real code and must be committed / present in a clone.
!apps/api/src/infra/storage/

# Logs
*.log
logs/

# Test / coverage
coverage/
.vitest/
test-results/
playwright-report/
